# Purpose: Safe example configuration for local Docker Compose and Unraid staging operation.
# Input/Output: Operators copy this file to `.env` and replace only the environment-specific placeholders.
# Invariants: No real secret belongs in this file, and production deployment stays disabled by default.
# Debugging: When a service cannot reach another service, a repo, or a model backend, verify the URLs and paths below first.
# Note: Define every key exactly once. Duplicate entries in `.env` are treated as a configuration error.

COMPOSE_PROJECT_NAME=feberdin-agent-team
APP_ENV=staging
LOG_LEVEL=INFO
PUID=99
PGID=100
BOOTSTRAP_UNRAID_SSH=false

HOST_DATA_DIR=/mnt/user/appdata/feberdin-agent-team/data
HOST_REPORTS_DIR=/mnt/user/appdata/feberdin-agent-team/reports
HOST_WORKSPACE_ROOT=/mnt/user/appdata/feberdin-agent-team/workspace
HOST_STAGING_STACK_ROOT=/mnt/user/appdata/feberdin-agent-team/staging-stacks
# Secret files must be world-readable (chmod 644) so the container user (PUID=99) can read them.
# Example: chmod 644 /mnt/user/appdata/feberdin-agent-team/secrets/*
HOST_SECRETS_DIR=/mnt/user/appdata/feberdin-agent-team/secrets

DATA_DIR=/data
REPORTS_DIR=/reports
WORKSPACE_ROOT=/workspace
TASK_WORKSPACE_ROOT=/workspace/.task-workspaces
STAGING_STACK_ROOT=/staging-stacks
RUNTIME_HOME_DIR=/tmp/agent-home

DEFAULT_TARGET_REPO=Feberdin/example-repo
DEFAULT_LOCAL_REPO_PATH=/workspace/example-repo
DEFAULT_BASE_BRANCH=main

ORCHESTRATOR_PORT=18080
WEB_UI_PORT=18088
ORCHESTRATOR_DB_PATH=/data/orchestrator.db
WEB_UI_INTERNAL_URL=http://web-ui:8088

REQUIREMENTS_WORKER_URL=http://requirements-worker:8090
RESEARCH_WORKER_URL=http://research-worker:8091
ARCHITECTURE_WORKER_URL=http://architecture-worker:8092
CODING_WORKER_URL=http://coding-worker:8093
REVIEWER_WORKER_URL=http://reviewer-worker:8094
TEST_WORKER_URL=http://test-worker:8095
GITHUB_WORKER_URL=http://github-worker:8096
DEPLOY_WORKER_URL=http://deploy-worker:8097
QA_WORKER_URL=http://qa-worker:8098
SECURITY_WORKER_URL=http://security-worker:8099
VALIDATION_WORKER_URL=http://validation-worker:8100
DOCUMENTATION_WORKER_URL=http://documentation-worker:8101
MEMORY_WORKER_URL=http://memory-worker:8102
DATA_WORKER_URL=http://data-worker:8103
UX_WORKER_URL=http://ux-worker:8104
COST_WORKER_URL=http://cost-worker:8105
HUMAN_RESOURCES_WORKER_URL=http://human-resources-worker:8106

MODEL_ROUTING_CONFIG=/app/config/model-routing.example.yaml
DEFAULT_MODEL_PROVIDER=mistral
MODEL_API_KEY=
MODEL_API_KEY_FILE=/run/project-secrets/model_api_key
LLM_CONNECT_TIMEOUT_SECONDS=30
LLM_READ_TIMEOUT_SECONDS=1200
LLM_WRITE_TIMEOUT_SECONDS=60
LLM_POOL_TIMEOUT_SECONDS=60
LLM_REQUEST_DEADLINE_SECONDS=1500
WORKER_CONNECT_TIMEOUT_SECONDS=30
WORKER_STAGE_TIMEOUT_SECONDS=1800
WORKER_WRITE_TIMEOUT_SECONDS=60
WORKER_POOL_TIMEOUT_SECONDS=60
WORKER_RETRY_ATTEMPTS=3
STAGE_HEARTBEAT_INTERVAL_SECONDS=30
READINESS_HTTP_FAST_TIMEOUT_SECONDS=8
READINESS_HTTP_DEEP_TIMEOUT_SECONDS=45
READINESS_LLM_SMOKE_TIMEOUT_SECONDS=240
READINESS_WORKER_SMOKE_TIMEOUT_SECONDS=20
READINESS_GIT_TIMEOUT_SECONDS=25
READINESS_SLOW_WARNING_SECONDS=20
MISTRAL_BASE_URL=http://192.168.57.10:11434/v1
QWEN_BASE_URL=http://192.168.57.10:11434/v1
MISTRAL_MODEL_NAME=mistral-small3.2:latest
QWEN_MODEL_NAME=qwen3.5:35b-a3b
MISTRAL_API_KEY=
MISTRAL_API_KEY_FILE=/run/project-secrets/mistral_api_key
QWEN_API_KEY=
QWEN_API_KEY_FILE=/run/project-secrets/qwen_api_key

CODING_PROVIDER=local_patch
OPENHANDS_BASE_URL=http://openhands:3000
OPENHANDS_ENABLED=false

WEB_RESEARCH_ENABLED=false
WEB_SEARCH_BASE_URL=
WEB_SEARCH_API_KEY=
WEB_SEARCH_API_KEY_FILE=/run/project-secrets/web_search_api_key
# Optional: only set this if you explicitly enable Brave as paid external fallback.
BRAVE_SEARCH_API_KEY=
BRAVE_SEARCH_API_KEY_FILE=/run/project-secrets/brave_search_api_key

GITHUB_TOKEN=replace-me-with-github-pat
GITHUB_TOKEN_FILE=/run/project-secrets/github_token
GITHUB_API_URL=https://api.github.com
GITHUB_MCP_ENABLED=false
GITHUB_MCP_BASE_URL=http://github-mcp:8787

GIT_AUTHOR_NAME=Feberdin Agent Team
GIT_AUTHOR_EMAIL=agent-team@local.feberdin
GIT_COMMIT_MESSAGE_PREFIX=feat(agent-team)

AUTO_DEBUG_ENABLED=false
AUTO_DEBUG_MAX_ATTEMPTS=2

# Self-host: SSH target for autonomous rebuild of the agent stack itself.
# Set SELF_HOST_SSH_HOST and SELF_HOST_PROJECT_DIR to enable fully autonomous self-update.
# The SSH key must be authorized on the target host (run scripts/setup_unraid_ssh.sh first).
SELF_HOST_SSH_USER=root
SELF_HOST_SSH_HOST=
SELF_HOST_SSH_PORT=22
SELF_HOST_PROJECT_DIR=
SELF_HOST_COMPOSE_FILE=docker-compose.yml
SELF_HOST_HEALTH_URL=http://localhost:18080/health

AUTO_DEPLOY_STAGING=true
STAGING_DEPLOY_STRATEGY=docker_compose
STAGING_HOST=unraid-staging.local
STAGING_SSH_PORT=22
STAGING_SSH_USER=appuser
STAGING_PROJECT_DIR=/mnt/user/appdata/feberdin-staging/example-app
STAGING_COMPOSE_FILE=docker-compose.staging.yml
STAGING_HEALTHCHECK_URL=http://unraid-staging.local:9000/health
STAGING_GIT_BRANCH=main
SELF_HOSTED_RUNNER_LABELS=self-hosted,linux,unraid,staging
