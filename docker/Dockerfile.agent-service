# Purpose: Shared container image for all Python services in the agent system.
# Input/Output: Docker builds a reusable runtime image with dependencies and the project source tree.
# Invariants: The image runs as a non-root user and keeps runtime state in mounted volumes.
# Debugging: If a service fails before binding its port, inspect the dependency install stage here first.

FROM python:3.11-slim

ARG BUILD_COMMIT_SHA=""
ARG BUILD_GIT_REF=""
ARG BUILD_BUILT_AT_UTC=""

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PYTHONPATH=/app \
    HOME=/tmp/agent-home \
    RUNTIME_HOME_DIR=/tmp/agent-home

WORKDIR /app

# Why this exists: git is needed for repo operations, and curl-like healthchecks are handled in Python.
# What happens here: install only the small set of OS packages the workers need for repo and process tasks.
RUN apt-get update \
    && apt-get install -y --no-install-recommends git openssh-client \
    && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /tmp/agent-home \
    && chmod 777 /tmp/agent-home

COPY docker/entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

COPY pyproject.toml README.md /app/
COPY config /app/config
COPY scripts /app/scripts
COPY services /app/services

# Why this exists:
# The running UI should show the image build time even when the mounted repo on
# the host changes later. Storing this outside `/app` keeps the metadata stable
# despite the bind mount that overlays the source tree at runtime.
RUN mkdir -p /opt/feberdin \
    && python - <<'PY'
import json
import os
from datetime import datetime, timezone
from pathlib import Path

built_at = os.environ.get("BUILD_BUILT_AT_UTC", "").strip()
if not built_at:
    built_at = datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")

payload = {
    "build_commit_sha": os.environ.get("BUILD_COMMIT_SHA", "").strip(),
    "build_git_ref": os.environ.get("BUILD_GIT_REF", "").strip(),
    "build_timestamp_utc": built_at,
}

Path("/opt/feberdin/build-info.json").write_text(
    json.dumps(payload, indent=2, ensure_ascii=True),
    encoding="utf-8",
)
PY

RUN python -m pip install --upgrade pip \
    && python -m pip install .

RUN useradd --create-home --uid 10001 appuser
USER appuser

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
