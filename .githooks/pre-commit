#!/usr/bin/env bash
# Pre-commit hook: run ruff, auto-fix what is fixable, fail if anything remains.
set -euo pipefail

RUFF=$(command -v ruff || true)
if [ -z "$RUFF" ]; then
  echo "pre-commit: ruff not found, skipping lint check." >&2
  exit 0
fi

echo "pre-commit: running ruff check ..."

# Auto-fix everything that ruff can fix without human input.
"$RUFF" check . --fix --quiet

# Re-check after fixes. If errors remain they require manual attention.
if ! "$RUFF" check . --quiet; then
  echo ""
  echo "pre-commit: ruff found errors that could not be auto-fixed." >&2
  echo "pre-commit: run 'ruff check .' to see details, fix manually, then re-commit." >&2
  exit 1
fi

echo "pre-commit: ruff OK."
